<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:MazeRL.UI"
        x:Class="MazeRL.UI.MainWindow"
        Title="MazeRL — reinforcement-learning playground"
        Width="1280" Height="860">
  <DockPanel>

    <!-- Top toolbar: the essentials, everything else lives behind ⚙ Settings -->
    <Border DockPanel.Dock="Top" Background="#22222A" Padding="10,8">
      <DockPanel>
        <ToggleButton x:Name="SettingsToggle" DockPanel.Dock="Right" Content="⚙ Settings"
                      IsCheckedChanged="OnSettingsToggled"/>
        <StackPanel Orientation="Horizontal" Spacing="10">
          <Button x:Name="StartPauseButton" Content="▶ Start training" Click="OnStartPause"/>
          <Button Content="Test run" Click="OnTestRun"/>
          <Button Content="Reset brain" Click="OnResetBrain"/>
          <Rectangle Width="1" Fill="#3A3A44" Margin="4,2"/>
          <TextBlock Text="Agent:" VerticalAlignment="Center" Foreground="Gray"/>
          <RadioButton x:Name="AgentQTable" Content="Q-table" GroupName="agent" IsChecked="True"/>
          <RadioButton x:Name="AgentDqn" Content="Neural net (DQN)" GroupName="agent"/>
          <Rectangle Width="1" Fill="#3A3A44" Margin="4,2"/>
          <TextBlock x:Name="SpeedLabel" Text="Speed: 20 episodes per tick" VerticalAlignment="Center"/>
          <Slider x:Name="SpeedSlider" Minimum="1" Maximum="500" Value="20" Width="150" VerticalAlignment="Center"/>
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- Settings panel: hidden until the ⚙ toggle is pressed -->
    <ScrollViewer x:Name="SettingsPanel" DockPanel.Dock="Right" Width="310" IsVisible="False">
      <StackPanel Margin="14" Spacing="10">

        <TextBlock Text="View" FontWeight="Bold" FontSize="16"/>
        <CheckBox x:Name="HeatmapCheck" Content="Q-value heatmap" IsChecked="True"/>
        <CheckBox x:Name="ArrowsCheck" Content="Policy arrows" IsChecked="True"/>
        <Border Background="#22222A" CornerRadius="4" Padding="8">
          <TextBlock x:Name="InspectorLabel" Text="Click a cell to inspect its Q-values."
                     TextWrapping="Wrap" FontFamily="Consolas,monospace" FontSize="12"/>
        </Border>

        <Separator/>
        <TextBlock Text="Maze editor" FontWeight="Bold" FontSize="16"/>
        <RadioButton x:Name="ModeWalls" Content="Draw / erase walls (drag)" IsChecked="True"/>
        <RadioButton x:Name="ModeStart" Content="Place start"/>
        <RadioButton x:Name="ModeGoal" Content="Place goal"/>
        <StackPanel Orientation="Horizontal" Spacing="8">
          <TextBlock Text="Rows" VerticalAlignment="Center"/>
          <NumericUpDown x:Name="RowsUpDown" Minimum="3" Maximum="40" Value="10" Increment="1" FormatString="0" Width="110"/>
          <TextBlock Text="Cols" VerticalAlignment="Center"/>
          <NumericUpDown x:Name="ColsUpDown" Minimum="3" Maximum="40" Value="10" Increment="1" FormatString="0" Width="110"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="8">
          <Button Content="Random maze" Click="OnRandomMaze"/>
          <Button Content="New empty maze" Click="OnNewMaze"/>
        </StackPanel>
        <Button Content="Clear walls" Click="OnClearWalls"/>

        <Separator/>
        <TextBlock Text="Save / load" FontWeight="Bold" FontSize="16"/>
        <StackPanel Orientation="Horizontal" Spacing="8">
          <Button Content="Save maze…" Click="OnSaveMaze"/>
          <Button Content="Load maze…" Click="OnLoadMaze"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="8">
          <Button Content="Save brain…" Click="OnSaveBrain"/>
          <Button Content="Load brain…" Click="OnLoadBrain"/>
        </StackPanel>
        <TextBlock Text="The brain file is just numbers as JSON — a Q-table for the tabular agent, weights and biases for the neural net."
                   TextWrapping="Wrap" FontSize="11" Foreground="Gray"/>
      </StackPanel>
    </ScrollViewer>

    <!-- Bottom strip: stats + learning curves on the left, the live network on the right -->
    <Border DockPanel.Dock="Bottom" Background="#16161C" Padding="8" Height="260">
      <Grid ColumnDefinitions="290,10,*">
        <StackPanel Grid.Column="0" Spacing="3">
          <TextBlock x:Name="StatsLabel" Text="Episodes: 0" FontFamily="Consolas,monospace" FontSize="12"/>
          <local:LineChart x:Name="StepsChart" Height="62"/>
          <TextBlock Text="steps per episode (last 300)" FontSize="10" Foreground="Gray"/>
          <local:LineChart x:Name="LossChart" Height="62" LabelFormat="0.###"/>
          <TextBlock Text="training loss (neural net only)" FontSize="10" Foreground="Gray"/>
        </StackPanel>
        <local:NetworkView Grid.Column="2" x:Name="NetView"/>
      </Grid>
    </Border>

    <!-- Center: the maze gets all remaining space -->
    <Border Background="#1B1B22" Padding="8">
      <local:MazeBoard x:Name="Board"/>
    </Border>
  </DockPanel>
</Window>
